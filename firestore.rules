rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções de Ajuda
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && exists(path) && get(path).data.get('isSuperAdmin', false) == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      let docData = get(path).data;
      return isAuthenticated() && exists(path) && docData.get('role', '') == role && docData.get('ativo', true) == true;
    }

    function belongsTo(companyId) {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && exists(path) && get(path).data.get('companyId', '') == companyId;
    }

    // Regras por Coleção
    
    // Coleção de Usuários
    match /users/{userId} {
      // ✅ O usuário SEMPRE pode ler/escrever seu próprio perfil (sem chamar getUserData())
      allow read: if request.auth.uid == userId;
      
      // Admin pode ler usuários da sua empresa. SuperAdmin pode ler todos.
      allow read: if isSuperAdmin() || 
                    (hasRole('admin') && belongsTo(resource.data.companyId));
      
      // Usuário pode atualizar apenas campos pessoais. SuperAdmin pode escrever qualquer coisa.
      allow write: if request.auth.uid == userId && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['nome', 'email', 'telefone', 'fotoUrl', 'primeiroAcesso', 'fotoBase64', 'faceDescriptor', 'senhaAlteradaEm', 'atualizadoEm']);
      
      // Admin pode atualizar dados de funcionários da mesma empresa
      allow update: if hasRole('admin') && belongsTo(resource.data.companyId);
      
      allow write: if isSuperAdmin();
    }

    // Coleção de Pontos
    match /pontos/{pontoId} {
      allow read: if isSuperAdmin() || 
                    request.auth.uid == resource.data.userId || 
                    (hasRole('admin') && belongsTo(resource.data.companyId));
      
      // Colaborador pode criar o próprio ponto (companyId deve bater com o perfil).
      // SuperAdmin pode criar ponto em qualquer empresa (para testes e correções).
      allow create: if isSuperAdmin() ||
                      (isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       (request.resource.data.companyId == getUserData().companyId ||
                        request.resource.data.companyId == "default"));
      
      allow update, delete: if isSuperAdmin() || 
                              (hasRole('admin') && belongsTo(resource.data.companyId));
    }

    // Coleção de Empresas
    match /companies/{companyId} {
      allow read, list: if true; // Permitido para check de login (slug/config)
      allow write: if isSuperAdmin();
      allow update: if hasRole('admin') && belongsTo(companyId);
    }



    // Coleção de Configurações Globais (Legacy)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Coleção de Justificativas de Ponto
    match /justificativas/{justId} {
      // Colaborador pode ler as próprias; admin pode ler as da empresa;
      allow read: if isSuperAdmin() ||
                    request.auth.uid == resource.data.userId ||
                    (hasRole('admin') && belongsTo(resource.data.companyId));

      // Colaborador pode criar a própria justificativa
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Aprovação/rejeição por admin
      allow update: if isSuperAdmin() ||
                      (hasRole('admin') && belongsTo(resource.data.companyId));
    }

    // Coleção de Banco de Horas
    match /banco_horas/{docId} {
      allow read: if isSuperAdmin() ||
                    (hasRole('admin') && belongsTo(resource.data.companyId)) ||
                    request.auth.uid == resource.data.userId;

      allow create: if isSuperAdmin() ||
                      (hasRole('admin') && request.resource.data.companyId == getUserData().companyId);

      allow update, delete: if isSuperAdmin() ||
                              (hasRole('admin') && belongsTo(resource.data.companyId));
    }

    // Coleção de Changelog (Notas de Atualização)
    match /changelog/{entryId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Coleção de Notificações
    match /notificacoes/{notifId} {
      allow read: if isSuperAdmin() ||
                    request.auth.uid == resource.data.userId ||
                    (hasRole('admin') && belongsTo(resource.data.companyId));
      
      // Admin pode criar notificações para funcionários da sua empresa
      allow create: if isSuperAdmin() ||
                      (hasRole('admin') && exists(/databases/$(database)/documents/users/$(request.resource.data.userId)) && 
                       get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data.companyId == getUserData().companyId);

      // Usuário pode marcar como lida (update)
      allow update: if isSuperAdmin() ||
                      request.auth.uid == resource.data.userId ||
                      (hasRole('admin') && belongsTo(resource.data.companyId));
      
      allow delete: if isSuperAdmin() ||
                      request.auth.uid == resource.data.userId ||
                      (hasRole('admin') && belongsTo(resource.data.companyId));
    }

    // Coleção de Suporte (Chat Master-Empresa)
    match /suporte_mensagens/{msgId} {
      // SuperAdmin lê tudo. Admin lê apenas da sua empresa.
      allow read: if isSuperAdmin() || 
                    (hasRole('admin') && belongsTo(resource.data.companyId));
      
      // Criação: SuperAdmin ou Admin da empresa. 
      // Deve garantir que o companyId está correto.
      allow create: if isSuperAdmin() || 
                      (hasRole('admin') && request.resource.data.companyId == getUserData().companyId);
      
      // SuperAdmin pode deletar
      allow delete: if isSuperAdmin();
    }

  }
}
